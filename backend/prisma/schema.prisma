generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WAITER
  CHEF
  CASHIER
  MANAGER
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      Role     @default(CUSTOMER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  deliveryOrders Order[] @relation("DeliveryAssignments")
  notifications Notification[]

  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean  @default(true)
  categoryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category           @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  recipe      RecipeIngredient[]

  @@map("menu_items")
}

model Order {
  id             String          @id @default(uuid())
  orderNumber    String          @unique
  userId         String?
  tableNumber    Int?
  status         OrderStatus     @default(PENDING)
  totalAmount    Decimal         @default(0) @db.Decimal(10, 2)
  paymentMethod  PaymentMethod?
  paidAt         DateTime?
  deliveryPersonId String?
  deliveryPerson   User?          @relation("DeliveryAssignments", fields: [deliveryPersonId], references: [id])
  deliveryAddress  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user       User?       @relation(fields: [userId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model InventoryItem {
  id        String   @id @default(uuid())
  name      String
  quantity  Decimal  @db.Decimal(10, 2)
  unit      String
  minStock  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes RecipeIngredient[]

  @@map("inventory_items")
}

model RecipeIngredient {
  id          String  @id @default(uuid())
  menuItemId  String
  inventoryId String
  quantity    Decimal @db.Decimal(10, 2)

  menuItem  MenuItem      @relation(fields: [menuItemId], references: [id])
  inventory InventoryItem @relation(fields: [inventoryId], references: [id])

  @@map("recipe_ingredients")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  title     String
  message   String
  type      String
  channel   String   @default("IN_APP")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("notifications")
}
